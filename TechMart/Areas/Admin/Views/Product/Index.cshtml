@model IReadOnlyList<TechMart.Presentation.Modules.Products.ViewModels.ProductListViewModel>
@{
    ViewData["Title"] = "Manage products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="h2 mb-0">Manage products</h1>
        <div class="d-flex flex-wrap gap-2">
            <a asp-area="" asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Shop</a>
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> New product
            </a>
        </div>
    </div>
    <p class="text-muted">No login required — for local development only.</p>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No products yet. Create one to get started.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th style="width: 72px;"></th>
                        <th>Name</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">Stock</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="" class="rounded" style="width: 56px; height: 56px; object-fit: cover;" />
                                }
                            </td>
                            <td>@item.Name</td>
                            <td class="text-end">$@item.Price.ToString("N2")</td>
                            <td class="text-center">@item.StockQuantity</td>
                            <td class="text-end text-nowrap">
                                <a asp-area="" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" target="_blank">View shop</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
