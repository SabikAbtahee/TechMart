@model TechMart.Presentation.Modules.Orders.ViewModels.OrderDetailsViewModel
@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">My orders</a></li>
            <li class="breadcrumb-item active" aria-current="page">Order #@Model.Id</li>
        </ol>
    </nav>

    <h1 class="h3 mb-2">Order #@Model.Id</h1>
    <p class="text-muted mb-4">@Model.OrderDate.ToLocalTime().ToString("g") · <span class="badge bg-secondary">@Model.Status</span></p>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header">Shipping</div>
                <div class="card-body">
                    <p class="mb-1 fw-semibold">@Model.CustomerName</p>
                    <p class="mb-1 small">@Model.Phone</p>
                    <p class="mb-1 small"><a href="mailto:@Model.Email">@Model.Email</a></p>
                    <p class="mb-0 small text-muted" style="white-space: pre-line;">@Model.ShippingAddress</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-header">Totals</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-6">Subtotal</dt>
                        <dd class="col-6 text-end">$@Model.SubTotal.ToString("N2")</dd>
                        <dt class="col-6">Tax</dt>
                        <dd class="col-6 text-end">$@Model.TaxAmount.ToString("N2")</dd>
                        <dt class="col-6">Shipping</dt>
                        <dd class="col-6 text-end">$@Model.ShippingAmount.ToString("N2")</dd>
                        <dt class="col-6 fw-bold">Total</dt>
                        <dd class="col-6 text-end fw-bold">$@Model.TotalAmount.ToString("N2")</dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5 mb-3">Items</h2>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th class="text-end">Price</th>
                    <th class="text-center">Qty</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.ProductName</td>
                        <td class="text-end">$@line.UnitPrice.ToString("N2")</td>
                        <td class="text-center">@line.Quantity</td>
                        <td class="text-end">$@line.LineTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <p class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">All orders</a>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Continue shopping</a>
    </p>
</div>
