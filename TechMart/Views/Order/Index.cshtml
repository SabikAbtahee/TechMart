@model TechMart.Presentation.Modules.Orders.ViewModels.OrderIndexViewModel
@{
    ViewData["Title"] = "My orders";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">My orders</h1>
    <p class="text-muted">Orders placed in this browser session.</p>

    @if (Model.Orders.Count == 0)
    {
        <div class="alert alert-info">You have not placed any orders yet.</div>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary">Browse products</a>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Order</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th class="text-end">Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model.Orders)
                    {
                        <tr>
                            <td>#@o.Id</td>
                            <td>@o.OrderDate.ToLocalTime().ToString("g")</td>
                            <td><span class="badge bg-secondary">@o.Status</span></td>
                            <td class="text-end">$@o.TotalAmount.ToString("N2")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
