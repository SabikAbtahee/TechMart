@model TechMart.Presentation.Modules.Checkout.ViewModels.CheckoutPageViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">Checkout</h1>

    <div class="row g-4">
        <div class="col-lg-5 order-lg-2">
            <div class="card shadow-sm">
                <div class="card-header">Order summary</div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        @foreach (var line in Model.Lines)
                        {
                            <li class="d-flex justify-content-between py-2 border-bottom">
                                <span>@line.ProductName × @line.Quantity</span>
                                <span>$@line.LineSubtotal.ToString("N2")</span>
                            </li>
                        }
                    </ul>
                    <dl class="row mb-0 mt-3 small">
                        <dt class="col-6">Subtotal</dt>
                        <dd class="col-6 text-end">$@Model.Subtotal.ToString("N2")</dd>
                        <dt class="col-6">Tax</dt>
                        <dd class="col-6 text-end">$@Model.TaxAmount.ToString("N2")</dd>
                        <dt class="col-6">Shipping</dt>
                        <dd class="col-6 text-end">$@Model.ShippingAmount.ToString("N2")</dd>
                        <dt class="col-6 fw-bold">Total</dt>
                        <dd class="col-6 text-end fw-bold">$@Model.Total.ToString("N2")</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="col-lg-7 order-lg-1">
            <div class="card shadow-sm">
                <div class="card-header">Shipping details</div>
                <div class="card-body">
                    <form asp-action="Index" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="CustomerName" class="form-label"></label>
                            <input asp-for="CustomerName" class="form-control" autocomplete="name" />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" autocomplete="tel" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ShippingAddress" class="form-label"></label>
                            <textarea asp-for="ShippingAddress" class="form-control" rows="3" autocomplete="street-address"></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary">Place order</button>
                            <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">Back to cart</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
