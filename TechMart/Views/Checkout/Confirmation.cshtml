@model TechMart.Presentation.Modules.Checkout.ViewModels.OrderConfirmationViewModel
@{
    ViewData["Title"] = "Order confirmation";
}

<div class="container mt-4">
    <div class="alert alert-success d-flex align-items-center gap-2" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <span>Thank you! Your order has been placed.</span>
    </div>

    <h1 class="h3 mb-3">Order #@Model.OrderId</h1>
    <p class="text-muted">Placed on @Model.OrderDate.ToLocalTime().ToString("g")</p>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th class="text-end">Price</th>
                    <th class="text-center">Qty</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>@line.ProductName</td>
                        <td class="text-end">$@line.UnitPrice.ToString("N2")</td>
                        <td class="text-center">@line.Quantity</td>
                        <td class="text-end">$@line.LineTotal.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <dl class="row justify-content-md-end">
        <dt class="col-sm-3 col-md-2">Subtotal</dt>
        <dd class="col-sm-9 col-md-3 text-md-end">$@Model.SubTotal.ToString("N2")</dd>
        <dt class="col-sm-3 col-md-2">Tax</dt>
        <dd class="col-sm-9 col-md-3 text-md-end">$@Model.TaxAmount.ToString("N2")</dd>
        <dt class="col-sm-3 col-md-2">Shipping</dt>
        <dd class="col-sm-9 col-md-3 text-md-end">$@Model.ShippingAmount.ToString("N2")</dd>
        <dt class="col-sm-3 col-md-2 fw-bold">Total</dt>
        <dd class="col-sm-9 col-md-3 text-md-end fw-bold">$@Model.TotalAmount.ToString("N2")</dd>
    </dl>

    <p class="mt-4 d-flex flex-wrap gap-2">
        <a asp-controller="Order" asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-primary">View order details</a>
        <a asp-controller="Order" asp-action="Index" class="btn btn-outline-primary">My orders</a>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary">Continue shopping</a>
    </p>
</div>
