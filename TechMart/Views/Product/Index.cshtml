@model IReadOnlyList<TechMart.Presentation.Modules.Products.ViewModels.ProductListViewModel>
@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
        <h1 class="display-4 mb-0">Products</h1>
        <a asp-controller="Cart" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-cart3"></i> Cart
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            <i class="bi bi-info-circle"></i> No products found.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <div class="p-3 pb-0">
                                <a asp-action="Details" asp-route-id="@item.Id" class="d-block rounded-3 overflow-hidden bg-light">
                                    <img src="@item.ImageUrl" class="w-100 d-block" alt="@item.Name" style="height: 200px; object-fit: cover;">
                                </a>
                            </div>
                        }
                        <div class="card-body d-flex flex-column @(string.IsNullOrEmpty(item.ImageUrl) ? "pt-4" : "pt-3")">
                            <h5 class="card-title">
                                <a asp-action="Details" asp-route-id="@item.Id" class="link-dark text-decoration-none">@item.Name</a>
                            </h5>
                            <p class="card-text text-muted small flex-grow-1">
                                @(item.Description.Length > 80 ? item.Description.Substring(0, 80) + "..." : item.Description)
                            </p>
                            <div class="mb-2">
                                <span class="h4 text-success fw-bold">$@item.Price.ToString("N2")</span>
                            </div>
                            <div class="mb-3">
                                @if (item.StockQuantity > 0)
                                {
                                    <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle">
                                        <i class="bi bi-check-circle"></i> @item.StockQuantity in stock
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">
                                        <i class="bi bi-x-circle"></i> Out of stock
                                    </span>
                                }
                            </div>

                            @if (item.StockQuantity > 0)
                            {
                                <form asp-controller="Cart" asp-action="Add" method="post" class="mt-auto">
                                    <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Product")" />
                                    <input type="hidden" name="productId" value="@item.Id" />
                                    <label class="form-label small text-muted mb-1" for="qty-@item.Id">Quantity</label>
                                    <div class="input-group input-group-sm mb-2">
                                        <input id="qty-@item.Id"
                                               type="number"
                                               name="quantity"
                                               class="form-control"
                                               value="1"
                                               min="1"
                                               max="@item.StockQuantity"
                                               aria-label="Quantity for @item.Name" />
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-cart-plus"></i> Add
                                        </button>
                                    </div>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary w-100 mt-auto" disabled>Unavailable</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <p class="text-muted small mt-4 mb-0">
            <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="link-secondary">Manage products (admin)</a>
        </p>
    }
</div>
