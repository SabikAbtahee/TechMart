@model TechMart.Presentation.Modules.Products.ViewModels.ProductEditViewModel
@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">@Model.Name</h2>
                </div>
                <div class="card-body">
                    <div class="row">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="col-md-4 mb-4 mb-md-0">
                                <div class="p-3 bg-light rounded-3">
                                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded w-100" />
                                </div>
                            </div>
                        }
                        <div class="@(string.IsNullOrEmpty(Model.ImageUrl) ? "col-12" : "col-md-8")">
                            <dl class="row">
                                <dt class="col-sm-4">Description</dt>
                                <dd class="col-sm-8">@Model.Description</dd>

                                <dt class="col-sm-4">Price</dt>
                                <dd class="col-sm-8">$@Model.Price.ToString("N2")</dd>

                                <dt class="col-sm-4">Stock Quantity</dt>
                                <dd class="col-sm-8">
                                    @if (Model.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success">@Model.StockQuantity in stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Out of stock</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">Created Date</dt>
                                <dd class="col-sm-8">@Model.CreatedDate.ToString("MMM dd, yyyy")</dd>

                                <dt class="col-sm-4">Last Updated</dt>
                                <dd class="col-sm-8">@Model.UpdatedDate.ToString("MMM dd, yyyy")</dd>
                            </dl>
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
