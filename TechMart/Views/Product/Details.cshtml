@model TechMart.Presentation.Modules.Products.ViewModels.ProductEditViewModel
@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">@Model.Name</h2>
                </div>
                <div class="card-body">
                    <div class="row">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="col-md-4 mb-4 mb-md-0">
                                <div class="p-3 bg-light rounded-3">
                                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded w-100" />
                                </div>
                            </div>
                        }
                        <div class="@(string.IsNullOrEmpty(Model.ImageUrl) ? "col-12" : "col-md-8")">
                            <dl class="row">
                                <dt class="col-sm-4">Description</dt>
                                <dd class="col-sm-8">@Model.Description</dd>

                                <dt class="col-sm-4">Price</dt>
                                <dd class="col-sm-8">$@Model.Price.ToString("N2")</dd>

                                <dt class="col-sm-4">Stock Quantity</dt>
                                <dd class="col-sm-8">
                                    @if (Model.StockQuantity > 0)
                                    {
                                        <span class="badge bg-success">@Model.StockQuantity in stock</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Out of stock</span>
                                    }
                                </dd>
                            </dl>

                            @if (Model.StockQuantity > 0)
                            {
                                <div class="border-top pt-3 mt-3">
                                    <h6 class="mb-3">Add to cart</h6>
                                    <form asp-controller="Cart" asp-action="Add" method="post" class="row g-2 align-items-end">
                                        <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Product", new { id = Model.Id })" />
                                        <input type="hidden" name="productId" value="@Model.Id" />
                                        <div class="col-auto">
                                            <label for="qty-details" class="form-label small mb-0">Quantity</label>
                                            <input id="qty-details" type="number" name="quantity" class="form-control" value="1" min="1" max="@Model.StockQuantity" style="width: 5.5rem;" />
                                        </div>
                                        <div class="col-auto">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-cart-plus"></i> Add to cart
                                            </button>
                                        </div>
                                    </form>
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        <form asp-controller="Cart" asp-action="Increment" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@Model.Id" />
                                            <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Product", new { id = Model.Id })" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">+1 in cart</button>
                                        </form>
                                        <form asp-controller="Cart" asp-action="Decrement" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@Model.Id" />
                                            <input type="hidden" name="returnUrl" value="@Url.Action("Details", "Product", new { id = Model.Id })" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">−1 in cart</button>
                                        </form>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0 mt-3">This item is currently unavailable.</p>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer d-flex flex-wrap gap-2">
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-cart3"></i> View cart
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to products
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
